<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>MorphicOracle</RootNamespace>
    <AssemblyName>morphic-oracle</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <InvariantGlobalization>true</InvariantGlobalization>

    <!-- Reproducible restores. Lockfile is committed; CI never restores. -->
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ValveResourceFormat" Version="19.1.6199" />
    <PackageReference Include="ValvePak" Version="4.0.0.142" />
  </ItemGroup>

</Project>
